# ── Stage 3 test suite — credentials template ────────────────────────────────
# Copy to `.env.test` (gitignored) for local integration/E2E runs, OR set these
# as GitHub Actions secrets for CI. NEVER commit real values.
#
# Use a DEDICATED Supabase TEST project/branch with NO real personal data — the
# suite seeds + tears down `t3test_` / 「測試學生_T3」 fixtures.

# Supabase test project. (The integration/E2E helpers also fall back to the
# app's NEXT_PUBLIC_SUPABASE_* + SUPABASE_SERVICE_ROLE_KEY if these are unset.)
TEST_SUPABASE_URL=
TEST_SUPABASE_ANON_KEY=
# service_role is used ONLY to seed/teardown fixtures — never to assert RLS.
TEST_SUPABASE_SERVICE_ROLE_KEY=

# Shared password for the seeded test users. REQUIRED for the Playwright E2E
# suite (its seed step and its browser-login workers are separate processes and
# must agree on the password). Pick a strong value; it is not a real account.
E2E_TEST_PASSWORD=

# Optional: point E2E at an already-running app (e.g. a Vercel preview) instead
# of letting Playwright start `npm run dev`.
# E2E_BASE_URL=https://your-preview.vercel.app
